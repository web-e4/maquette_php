{% extends "base.html.twig" %}

{% block title %}{{ offer.title }}{% endblock %}

{% block meta_description %}Offre de stage : {{ offer.title }} chez {{ offer.companyName }} à {{ offer.location }}. Durée : {{ offer.durationInWeeks }} semaines. Postulez sur GigaStage.{% endblock %}
{% block meta_keywords %}stage {{ offer.title }}, stage {{ offer.location }}, {{ offer.companyName }}, offre stage{% endblock %}

{% block styles %}<link rel="stylesheet" href="{{ static_url }}/assets/css/offer.css">{% endblock %}

{% block content %}

    <main>

        <!-- HEADER OFFRE -->
        <header class="job-header">
            <div class="container job-header-inner">

                <div class="job-title-group">
                    <h1>{{ offer.title }}</h1>

                    <a class="company-name" href="/company/{{ offer.idCompany }}">
                        <img src="{{ static_url }}/assets/icons/building-2.svg" alt="">
                        {{ offer.companyName }}
                    </a>
                </div>

                {% if app_user is not null and app_user.role == 'Etudiant' %}
                  <form method="post" action="{{ inWishlist ? '/wishlist/remove' : '/wishlist/add' }}?id={{ offer.idOffer }}">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="redirect" value="{{ current_url }}">
                    <button class="btn {{ inWishlist ? 'btn-solid' : 'btn-ghost' }}" type="submit">
                      <img src="{{ static_url }}/assets/icons/heart.svg" alt="" style="width:16px;height:16px;filter:{{ inWishlist ? 'brightness(0) invert(1)' : 'invert(33%) sepia(60%) saturate(500%) hue-rotate(175deg) brightness(85%)' }};margin-right:6px">
                      {{ inWishlist ? 'Dans ma wish-list' : 'Wish-list' }}
                    </button>
                  </form>
                {% endif %}

            </div>
        </header>

        <div class="container">
            <div class="job-grid">

                <!-- CONTENU -->
                <div class="job-content">

                    <section>
                        <h2>Description du poste</h2>
                        <p>{{ offer.description }}</p>
                    </section>

                    <section>
                        <h2>Missions confiées</h2>
                        <ul class="missions-list">
                            {% for mission in offer.missions|split(',') %}
                                <li class="missions-item">{{ mission|trim }}</li>
                            {% endfor %}
                        </ul>
                    </section>

                </div>

                <!-- SIDEBAR -->
                <aside>
                    <div class="sidebar-card">

                        <div class="info-item">
                            <img src="{{ static_url }}/assets/icons/map-pin.svg" alt="">
                            <span>
                                <strong>Lieu :</strong>
                                {{ offer.location }}
                            </span>
                        </div>

                        <div class="info-item">
                            <img src="{{ static_url }}/assets/icons/clock.svg" alt="">
                            <span>
                                <strong>Durée :</strong>
                                {{ offer.durationInWeeks }} semaines
                            </span>
                        </div>

                        <div class="info-item">
                            <img src="{{ static_url }}/assets/icons/calendar.svg" alt="">
                            <span>
                                <strong>Début :</strong>
                                {{ offer.startDate }}
                            </span>
                        </div>

                        <div class="info-item">
                            <img src="{{ static_url }}/assets/icons/pencil.svg" alt="">
                            <span>
                                <strong>Publiée le :</strong>
                                {{ offer.createdAt }}
                            </span>
                        </div>

                        <div class="info-item">
                            <img src="{{ static_url }}/assets/icons/send.svg" alt="">
                            <span>
                                <strong>Candidatures :</strong>
                                {{ applicationCount }}
                            </span>
                        </div>

                        <hr class="separator">

                        {% if app_user is not null and app_user.role == 'Etudiant' %}
                          <a href="/apply/{{ offer.idOffer }}" class="btn btn-solid w-full">
                            <img src="{{ static_url }}/assets/icons/send.svg" alt="" class="icon-white">
                            Postuler maintenant
                          </a>
                        {% else %}
                          <button class="btn btn-solid w-full" disabled style="opacity:0.5;cursor:not-allowed">
                            <img src="{{ static_url }}/assets/icons/lock.svg" alt="" style="width:15px;height:15px;filter:brightness(0) invert(1);margin-right:6px">
                            Postuler maintenant
                          </button>
                        {% endif %}

                    </div>
                </aside>

            </div>
        </div>

    </main>

{% endblock %}
