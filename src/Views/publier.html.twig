{% extends "base.html.twig" %}

{% block title %}Publier une offre{% endblock %}

{% block content %}

<main class="publish-page">
  <div class="container">

    <!-- EN-TÊTE -->
    <div class="publish-header">
      <h1>Publier une offre de stage</h1>
      <p>Remplissez le formulaire ci-dessous pour mettre en ligne votre offre.</p>
    </div>

    <!-- ERREURS -->
    {% if errors is defined %}
      <div class="form-errors">
        <ul>
          {% for error in errors %}
            <li>{{ error }}</li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    <!-- FORMULAIRE -->
    <form class="publish-form" method="post" action="/publier_offre">

      <!-- Intitulé -->
      <div class="form-field">
        <label class="form-label" for="title">
          Intitulé de l'offre <span class="required">*</span>
        </label>
        <input
          class="form-input"
          type="text"
          id="title"
          name="title"
          value="{{ formData.title|default('') }}"
          placeholder="Ex : Stage Développeur Web"
          required
        >
      </div>

      <!-- Localisation -->
      <div class="form-field">
        <label class="form-label" for="location">
          Localisation <span class="required">*</span>
        </label>
        <input
          class="form-input"
          type="text"
          id="location"
          name="location"
          value="{{ formData.location|default('') }}"
          placeholder="Ex : Rouen (76)"
          required
        >
      </div>

      <!-- Durée -->
      <div class="form-field">
        <label class="form-label" for="duration">
          Durée <span class="required">*</span>
        </label>
        <input
          class="form-input"
          type="text"
          id="duration"
          name="duration"
          value="{{ formData.duration|default('') }}"
          placeholder="Ex : 6 mois"
          required
        >
      </div>

      <!-- Date de début -->
      <div class="form-field">
        <label class="form-label" for="date_debut">
          Date de début <span class="required">*</span>
        </label>
        <input
          class="form-input"
          type="date"
          id="date_debut"
          name="date_debut"
          value="{{ formData.date_debut|default('') }}"
          required
        >
      </div>

      <!-- Description -->
      <div class="form-field field-full">
        <label class="form-label" for="description">
          Description du poste <span class="required">*</span>
        </label>
        <textarea
          class="form-textarea"
          id="description"
          name="description"
          placeholder="Décrivez le contexte, l'équipe, les objectifs du stage..."
          required
        >{{ formData.description|default('') }}</textarea>
      </div>

      <!-- Missions -->
      <div class="form-field field-full">
        <label class="form-label" for="missions">
          Missions confiées <span class="required">*</span>
        </label>
        <textarea
          class="form-textarea"
          id="missions"
          name="missions"
          placeholder="Ex : Développer des fonctionnalités, Corriger les bugs, Rédiger la documentation"
          required
        >{{ formData.missions|default('') }}</textarea>
        <span class="field-hint">Séparez chaque mission par une virgule.</span>
      </div>

      <!-- Actions -->
      <div class="publish-actions">
        <button class="btn btn-solid" type="submit">
          <img src="/assets/icons/send.svg" alt="" class="icon-white">
          Publier l'offre
        </button>
        <a class="btn btn-ghost" href="/">Annuler</a>
      </div>

    </form>

  </div>
</main>

{% endblock %}