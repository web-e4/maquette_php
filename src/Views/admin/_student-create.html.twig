<div class="admin-form-card">
  <h3>Nouveau compte étudiant</h3>
  <form method="post" action="/admin/student/create">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <div class="admin-form-grid">
      <div class="form-field">
        <label class="form-label" for="sc-firstname">Prénom <span class="required">*</span></label>
        <input class="form-input" type="text" id="sc-firstname" name="firstName" required>
      </div>
      <div class="form-field">
        <label class="form-label" for="sc-surname">Nom <span class="required">*</span></label>
        <input class="form-input" type="text" id="sc-surname" name="surname" required>
      </div>
      <div class="form-field">
        <label class="form-label" for="sc-email">Email <span class="required">*</span></label>
        <input class="form-input" type="email" id="sc-email" name="email" required>
      </div>
      <div class="form-field">
        <label class="form-label" for="sc-password">Mot de passe <span class="required">*</span></label>
        <input class="form-input" type="password" id="sc-password" name="password" required>
      </div>
    </div>
    <div class="admin-form-actions">
      <button class="btn btn-solid" type="submit">Créer le compte</button>
      <button class="btn btn-ghost" type="button" onclick="toggleForm('form-student-create')">Annuler</button>
    </div>
  </form>
</div>
