{% extends "base.html.twig" %}

{% block title %}Contact{% endblock %}

{% block meta_description %}Contactez l'équipe GigaStage pour toute question ou demande d'assistance. Nous sommes à votre écoute.{% endblock %}
{% block meta_keywords %}contact GigaStage, assistance, support, question, aide{% endblock %}

{% block styles %}<link rel="stylesheet" href="{{ static_url }}/assets/css/pages.css">{% endblock %}

{% block content %}

<main class="page-content">
  <div class="container">

    <h1>Contactez-nous</h1>
    <p class="page-subtitle">
      Une question ? Un problème ? Écrivez-nous à
      <a href="mailto:giga.stage@viacesi.fr"><strong>giga.stage@viacesi.fr</strong></a>
      ou utilisez le formulaire ci-dessous.
    </p>

    {% if flash %}
      <div class="alert {{ flash.type }}">{{ flash.message }}</div>
    {% endif %}

    <form class="contact-form" action="/contact" method="post" novalidate>
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

      <div>
        <label for="name">Votre nom</label>
        <input
          id="name"
          name="name"
          type="text"
          value="{{ old.name }}"
          placeholder="Jean Dupont"
          required
        >
        {% if errors.name %}
          <small class="error">{{ errors.name }}</small>
        {% endif %}
      </div>

      <div>
        <label for="email">Votre email</label>
        <input
          id="email"
          name="email"
          type="email"
          value="{{ old.email }}"
          placeholder="vous@exemple.com"
          required
        >
        {% if errors.email %}
          <small class="error">{{ errors.email }}</small>
        {% endif %}
      </div>

      <div>
        <label for="message">Votre message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="Décrivez votre demande..."
          required
        >{{ old.message }}</textarea>
        {% if errors.message %}
          <small class="error">{{ errors.message }}</small>
        {% endif %}
      </div>

      <button class="btn btn-solid" type="submit">Envoyer</button>
    </form>

    <div class="contact-address">
      <h2>Notre adresse</h2>
      <address>
        80 avenue Edmund Halley<br>
        Rouen Madrillet Innovation<br>
        76800 Saint-Étienne-du-Rouvray
      </address>
    </div>

  </div>
</main>

{% endblock %}
