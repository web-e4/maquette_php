{% extends "base.html.twig" %}

{% block title %}Mon profil{% endblock %}

{% block content %}

<main class="profile-page">
  <div class="container">

    <!-- ===== HEADER PROFIL ===== -->
    <div class="profile-header">
      <h1>{{ stagiaire.prenom }} {{ stagiaire.nom }}</h1>
      <p class="profile-meta">{{ stagiaire.email }} — {{ stagiaire.ville }}</p>

      <a class="btn btn-ghost" href="{{ path('app_stagiaire_edit') }}">
        Modifier le profil
      </a>
    </div>

    <!-- ===== OFFRES FAVORITES ===== -->
    <section>
      <div class="section-header">
        <h2>Offres favorites</h2>
        <span class="count-badge">{{ favoris|length }}</span>
      </div>

      <div class="profile-offers">

        {% for offre in favoris %}
          <article class="profile-offer-card">

            <div class="profile-offer-body">
              <h3>{{ offre.titre }}</h3>
              <div class="profile-offer-meta">
                <span>{{ offre.localisation }}</span>
                <span>{{ offre.duree }}</span>
                <span>{{ offre.entreprise.nom }}</span>
              </div>
            </div>

            <div class="profile-offer-actions">
              <a class="btn btn-solid" href="{{ path('app_offre_show', {id: offre.id}) }}">
                Voir
              </a>
              <form method="post" action="{{ path('app_favoris_remove', {id: offre.id}) }}">
                <button class="btn-icon btn-icon--danger" type="submit" aria-label="Retirer des favoris">
                  Retirer
                </button>
              </form>
            </div>

          </article>
        {% else %}
          <p>Aucune offre favorite.</p>
        {% endfor %}

      </div>
    </section>

    <!-- ===== INFOS STAGIAIRE ===== -->
    <section>
      <div class="section-header">
        <h2>Mes informations</h2>
      </div>

      <div class="profile-info">
        <p><strong>Prénom :</strong> {{ stagiaire.prenom }}</p>
        <p><strong>Nom :</strong> {{ stagiaire.nom }}</p>
        <p><strong>Email :</strong> {{ stagiaire.email }}</p>
        <p><strong>Ville :</strong> {{ stagiaire.ville }}</p>
        <p><strong>École / Établissement :</strong> {{ stagiaire.ecole }}</p>
      </div>
    </section>

  </div>
</main>

{% endblock %}
