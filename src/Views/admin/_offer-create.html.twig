<div class="admin-form-card">
  <h3>Nouvelle offre</h3>
  <form method="post" action="/offer/create/submit">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <div class="admin-form-grid">

      <div class="form-field">
        <label class="form-label" for="oc-title">Intitulé <span class="required">*</span></label>
        <input class="form-input" type="text" id="oc-title" name="title" placeholder="Ex : Stage Développeur Web" required>
      </div>

      <div class="form-field">
        <label class="form-label" for="oc-company">Entreprise <span class="required">*</span></label>
        <select class="form-input" id="oc-company" name="idCompany" required>
          <option value="">- Sélectionner -</option>
          {% for company in companies %}
            <option value="{{ company.idCompany }}">{{ company.name }}</option>
          {% endfor %}
        </select>
      </div>

      <div class="form-field">
        <label class="form-label" for="oc-location">Localisation <span class="required">*</span></label>
        <input class="form-input" type="text" id="oc-location" name="location" placeholder="Ex : Rouen (76)" required>
      </div>

      <div class="form-field">
        <label class="form-label" for="oc-duration">Durée (semaines) <span class="required">*</span></label>
        <input class="form-input" type="number" id="oc-duration" name="duration" min="1" placeholder="Ex : 12" required>
      </div>

      <div class="form-field">
        <label class="form-label" for="oc-start">Date de début <span class="required">*</span></label>
        <input class="form-input" type="date" id="oc-start" name="startDate" required>
      </div>

      <div class="form-field field-full">
        <label class="form-label" for="oc-desc">Description <span class="required">*</span></label>
        <textarea class="form-textarea" id="oc-desc" name="description" placeholder="Contexte, équipe, objectifs..." required></textarea>
      </div>

      <div class="form-field field-full">
        <label class="form-label" for="oc-missions">Missions <span class="required">*</span></label>
        <textarea class="form-textarea" id="oc-missions" name="missions" placeholder="Ex : Développer des fonctionnalités, Corriger les bugs" required></textarea>
        <span class="field-hint">Séparez chaque mission par une virgule.</span>
      </div>

    </div>

    <input type="hidden" name="redirectTo" value="{{ dashboardBase }}?tab=offers">

    <div class="admin-form-actions">
      <button class="btn btn-solid" type="submit">Publier l'offre</button>
      <button class="btn btn-ghost" type="button" onclick="toggleForm('form-offer-create')">Annuler</button>
    </div>
  </form>
</div>
