{% extends "base.html.twig" %}

{% block title %}
	{{ offre.titre }}
{% endblock %}

{% block content %}

	<main>

		<!-- HEADER OFFRE -->
		<header class="job-header">
			<div class="container job-header-inner">

				<div class="job-title-group">
					<h1>{{ offre.titre }}</h1>

					<p class="company-name">
						<img src="/assets/icons/building-2.svg" alt="">
						{{ offre.entreprise.nom }}
					</p>
				</div>

				{% if offre.verifiee %}
					<div class="job-badges">
						<span class="btn btn-outline-secondary">Offre vérifiée</span>
					</div>
				{% endif %}

			</div>
		</header>

		<div class="container">
			<div
				class="job-grid">

				<!-- CONTENU -->
				<article class="job-content">

					<section>
						<h2>Description du poste</h2>
						<p>{{ offre.description }}</p>
					</section>

					<section>
						<h2>Missions confiées</h2>
						<ul class="missions-list">
							{% for mission in offre.missions|split(',') %}
								<li class="missions-item">{{ mission|trim }}</li>
							{% endfor %}
						</ul>
					</section>

				</article>

				<!-- SIDEBAR -->
				<aside>
					<div class="sidebar-card">

						<div class="info-item">
							<img src="/assets/icons/map-pin.svg" alt="">
							<span>
								<strong>Lieu :</strong>
								{{ offre.ville }}
							</span>
						</div>

						<div class="info-item">
							<img src="/assets/icons/clock.svg" alt="">
							<span>
								<strong>Durée :</strong>
								{{ offre.duree }}
							</span>
						</div>

						<div class="info-item">
							<img src="/assets/icons/calendar.svg" alt="">
							<span>
								<strong>Début :</strong>
								{{ offre.date_debut }}
							</span>
						</div>

						<hr class="separator">

						<a href="/postuler?id={{ offre.id }}" class="btn btn-solid w-full">
							<img src="/assets/icons/send.svg" alt="" class="icon-white">
							Postuler maintenant
						</a>

						{% if app.user %}
							<button class="btn btn-fav w-full" type="button">
								<img src="/assets/icons/heart.svg" alt="">
								{% if offre.est_favori %}
									Enregistré
								{% else %}
									Mettre en favoris
								{% endif %}
							</button>
						{% endif %}

					</div>
				</aside>

			</div>
		</div>

	</main>

{% endblock %}
