<div class="admin-form-card">
  <h3>Modifier l'offre</h3>
  <form method="post" action="/offer/edit?id={{ offer.idOffer }}">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <input type="hidden" name="redirectTo" value="{{ dashboardBase }}?tab=offers">
    <div class="admin-form-grid">
      <div class="form-field field-full">
        <label class="form-label" for="oe-title">Intitulé <span class="required">*</span></label>
        <input class="form-input" type="text" id="oe-title" name="title" value="{{ offer.title }}" required>
      </div>
      <div class="form-field">
        <label class="form-label" for="oe-location">Localisation <span class="required">*</span></label>
        <input class="form-input" type="text" id="oe-location" name="location" value="{{ offer.location }}" required>
      </div>
      <div class="form-field">
        <label class="form-label" for="oe-duration">Durée (semaines) <span class="required">*</span></label>
        <input class="form-input" type="number" id="oe-duration" name="duration" value="{{ offer.durationInWeeks }}" min="1" required>
      </div>
      <div class="form-field">
        <label class="form-label" for="oe-startDate">Date de début <span class="required">*</span></label>
        <input class="form-input" type="date" id="oe-startDate" name="startDate" value="{{ offer.startDate }}" required>
      </div>
      <div class="form-field">
        <label class="form-label" for="oe-status">État</label>
        <select class="form-input" id="oe-status" name="statusOffer">
          <option value="1" {{ offer.statusOffer == 1 ? 'selected' : '' }}>Activé</option>
          <option value="0" {{ offer.statusOffer == 0 ? 'selected' : '' }}>Désactivé</option>
        </select>
      </div>
      <div class="form-field field-full">
        <label class="form-label" for="oe-description">Description <span class="required">*</span></label>
        <textarea class="form-input" id="oe-description" name="description" rows="4" required>{{ offer.description }}</textarea>
      </div>
      <div class="form-field field-full">
        <label class="form-label" for="oe-missions">Missions (séparées par virgule) <span class="required">*</span></label>
        <textarea class="form-input" id="oe-missions" name="missions" rows="3" required>{{ offer.missions }}</textarea>
      </div>
    </div>
    <div class="admin-form-actions">
      <button class="btn btn-solid" type="submit">Enregistrer</button>
      <a href="{{ dashboardBase }}?tab=offers" class="btn btn-ghost">Annuler</a>
    </div>
  </form>
</div>
