{% extends "base.html.twig" %}

{% block title %}Postuler — {{ offre.titre }}{% endblock %}

{% block content %}

<main class="publish-page">
  <div class="container">

    <!-- EN-TÊTE -->
    <div class="publish-header">
      <h1>Postuler à l'offre</h1>
      <p>
        <strong>{{ offre.titre }}</strong> chez {{ offre.entreprise.nom }} — {{ offre.ville }}
      </p>
    </div>

    <!-- FORMULAIRE -->
    <form class="publish-form" action="/postuler/{{ offre.id }}" method="post" enctype="multipart/form-data">

      <!-- Nom -->
      <div class="form-field">
        <label class="form-label" for="nom">
          Nom <span class="required">*</span>
        </label>
        <input
          class="form-input"
          type="text"
          id="nom"
          name="nom"
          placeholder="Dupont"
          required
        >
      </div>

      <!-- Prénom -->
      <div class="form-field">
        <label class="form-label" for="prenom">
          Prénom <span class="required">*</span>
        </label>
        <input
          class="form-input"
          type="text"
          id="prenom"
          name="prenom"
          placeholder="Marie"
          required
        >
      </div>

      <!-- Email -->
      <div class="form-field field-full">
        <label class="form-label" for="email">
          Adresse email <span class="required">*</span>
        </label>
        <input
          class="form-input"
          type="email"
          id="email"
          name="email"
          placeholder="marie.dupont@email.com"
          required
        >
      </div>

      <!-- Genre -->
      <div class="form-field field-full">
        <label class="form-label" for="genre">
          Genre <span class="required">*</span>
        </label>
        <select class="form-select" id="genre" name="genre" required>
          <option value="" disabled selected>Sélectionner...</option>
          <option value="femme">Femme</option>
          <option value="homme">Homme</option>
          <option value="autre">Autre / Préfère ne pas préciser</option>
        </select>
      </div>

      <!-- CV -->
      <div class="form-field">
        <label class="form-label" for="cv">
          Curriculum Vitae (PDF) <span class="required">*</span>
        </label>
        <input
          class="form-input"
          type="file"
          id="cv"
          name="cv"
          accept=".pdf"
          required
        >
        <span class="field-hint">Fichier PDF uniquement, 5 Mo maximum.</span>
      </div>

      <!-- Lettre de motivation -->
      <div class="form-field">
        <label class="form-label" for="lettre">
          Lettre de motivation (PDF) <span class="required">*</span>
        </label>
        <input
          class="form-input"
          type="file"
          id="lettre"
          name="lettre"
          accept=".pdf"
          required
        >
        <span class="field-hint">Fichier PDF uniquement, 5 Mo maximum.</span>
      </div>

      <!-- Actions -->
      <div class="publish-actions">
        <button class="btn btn-solid" type="submit">
          <img src="/assets/icons/send.svg" alt="" class="icon-white">
          Envoyer ma candidature
        </button>
        <a class="btn btn-ghost" href="/offre?id={{ offre.id }}">
          Annuler
        </a>
      </div>

    </form>

  </div>
</main>

{% endblock %}
