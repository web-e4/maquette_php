{% extends "base.html.twig" %}

{% block title %}Postuler - {{ offer.title }}{% endblock %}

{% block styles %}<link rel="stylesheet" href="{{ static_url }}/assets/css/apply.css">{% endblock %}

{% block content %}

<main class="publish-page">
  <div class="container">

    <!-- en-tête -->
    <div class="publish-header">
      <h1>Postuler à l'offre</h1>
      <p>
        <strong>{{ offer.title }}</strong> chez {{ offer.companyName }} - {{ offer.location }}
      </p>
    </div>

    <!-- message flash -->
    {% if flash %}
      <div class="flash flash--{{ flash.type }}">
        {{ flash.message }}
      </div>
    {% endif %}

    {% if alreadyApplied %}

      <!-- mode lecture : candidature déjà envoyée -->
      <div class="application-summary">

        <div class="form-field">
          <span class="form-label">Nom</span>
          <div class="summary-row">
            <span class="form-input summary-value">{{ application.surname }}</span>
          </div>
        </div>

        <div class="form-field">
          <span class="form-label">Prénom</span>
          <div class="summary-row">
            <span class="form-input summary-value">{{ application.firstName }}</span>
          </div>
        </div>

        <div class="form-field field-full">
          <span class="form-label">Adresse email</span>
          <div class="summary-row">
            <span class="form-input summary-value">{{ application.email }}</span>
          </div>
        </div>

        <div class="form-field field-full">
          <span class="form-label">CV déposé</span>
          <div class="summary-row">
            {% if resumeExists %}
              <a class="form-input summary-value" href="{{ static_url }}/{{ application.resume }}" target="_blank" style="color: var(--color-primary-dark)">
                {{ application.resume|split('/')|last }}
              </a>
            {% else %}
              <span class="form-input summary-value" style="color: var(--color-error, #b91c1c)">Fichier manquant</span>
            {% endif %}
            <button class="btn-edit" type="button" data-field="cv" title="Remplacer">
              <img src="{{ static_url }}/assets/icons/pencil.svg" alt="Remplacer">
            </button>
          </div>
        </div>

        <div class="form-field field-full">
          <span class="form-label">Lettre de motivation</span>
          <div class="summary-row" data-section="letter">
            {% if application.motivationLetter %}
              <p class="form-input summary-value letter-text" style="white-space: pre-wrap; min-height: 80px">{{ application.motivationLetter }}</p>
              <button class="btn-edit" type="button" data-field="letter" title="Modifier">
                <img src="{{ static_url }}/assets/icons/pencil.svg" alt="Modifier">
              </button>
            {% else %}
              <span class="form-input summary-value" style="color: var(--color-text-muted)">Non fournie</span>
              <button class="btn-edit" type="button" data-field="letter" title="Ajouter">
                <img src="{{ static_url }}/assets/icons/pencil.svg" alt="Ajouter">
              </button>
            {% endif %}
          </div>
        </div>

        <div class="publish-actions field-full">
          <a class="btn btn-ghost" href="/">Retour à l'accueil</a>
        </div>

      </div>

    {% else %}

      <!-- mode formulaire : pas encore postulé -->
      <form class="publish-form" action="/apply/submit?id={{ offer.idOffer }}" method="post" enctype="multipart/form-data">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

        <div class="form-field">
          <label class="form-label" for="surname">Nom</label>
          <input class="form-input" type="text" id="surname" name="surname"
            value="{{ profile.surname }}" readonly tabindex="-1">
        </div>

        <div class="form-field">
          <label class="form-label" for="firstName">Prénom</label>
          <input class="form-input" type="text" id="firstName" name="firstName"
            value="{{ profile.firstName }}" readonly tabindex="-1">
        </div>

        <div class="form-field field-full">
          <label class="form-label" for="email">Adresse email</label>
          <input class="form-input" type="email" id="email" name="email"
            value="{{ profile.email }}" readonly tabindex="-1">
        </div>

        <div class="form-field">
          <label class="form-label" for="cv">Curriculum Vitae (PDF) <span class="required">*</span></label>
          <label class="file-upload-btn" for="cv">
            <img src="{{ static_url }}/assets/icons/upload.svg" alt="">
            <span class="file-upload-label" id="cv-label">Choisir un fichier PDF</span>
          </label>
          <input class="file-input-hidden" type="file" id="cv" name="cv" accept=".pdf" required>
          <span class="field-hint">Fichier PDF uniquement, 5 Mo maximum.</span>
        </div>

        <div class="form-field field-full">
          <label class="form-label" for="letter">Lettre de motivation</label>
          <textarea class="form-input" id="letter" name="letter" rows="6" placeholder="Rédigez votre lettre de motivation ici..."></textarea>
          <span class="field-hint">Facultatif. Expliquez vos motivations en quelques lignes.</span>
        </div>

        <div class="publish-actions">
          <button class="btn btn-solid" type="submit">
            <img src="{{ static_url }}/assets/icons/send.svg" alt="" class="icon-white">
            Envoyer ma candidature
          </button>
          <a class="btn btn-ghost" href="/">Annuler</a>
        </div>

      </form>

      <script>
        var cvInput = document.getElementById('cv');
        if (cvInput) {
          cvInput.addEventListener('change', function() {
            var label = document.getElementById('cv-label');
            label.textContent = this.files[0] ? this.files[0].name : 'Choisir un fichier PDF';
          });
        }
      </script>

    {% endif %}
  </div>
</main>

{% endblock %}

{% block scripts %}
  {% if alreadyApplied %}
    <script src="{{ static_url }}/assets/js/application-edit.js"></script>
  {% endif %}
{% endblock %}
