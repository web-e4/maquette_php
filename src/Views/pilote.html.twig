{% extends "base.html.twig" %}

{% block title %}Espace pilote{% endblock %}

{% block content %}

<main class="pilot">
  <div class="container">

    <h1>Gestion pilote</h1>

    {% if success %}
      <div class="alert success">{{ success }}</div>
    {% endif %}

    {% if errors %}
      <div class="alert error">
        {% for error in errors %}
          <p>{{ error }}</p>
        {% endfor %}
      </div>
    {% endif %}

    <!-- ENTREPRISE -->
    <section>
      <h2>Entreprises</h2>

      {% include "admin/_company_create.html.twig" %}
      {% include "admin/_company_update.html.twig" %}
      {% include "admin/_company_delete.html.twig" %}
      {% include "admin/_company_evaluate.html.twig" %}
    </section>

    <!-- OFFRES -->
    <section>
      <h2>Offres</h2>

      {% include "admin/_offer_create.html.twig" %}
      {% include "admin/_offer_update.html.twig" %}
      {% include "admin/_offer_delete.html.twig" %}
    </section>

    <!-- ETUDIANTS -->
    <section>
      <h2>Comptes étudiants</h2>

      {% include "admin/_student_create.html.twig" %}
      {% include "admin/_student_update.html.twig" %}
      {% include "admin/_student_delete.html.twig" %}
    </section>

    <!-- SUIVI DES CANDIDATURES -->
    <section>
      <h2>Suivi des candidatures</h2>

      <table class="table">
        <thead>
          <tr>
            <th>ID Étudiant</th>
            <th>Nom</th>
            <th>ID Offre</th>
            <th>Offre</th>
            <th>Entreprise</th>
          </tr>
        </thead>

        <tbody>
          {% for candidature in candidatures %}
            <tr>
              <td>{{ candidature.etudiant.id }}</td>
              <td>{{ candidature.etudiant.nom }}</td>
              <td>{{ candidature.offre.id }}</td>
              <td>{{ candidature.offre.titre }}</td>
              <td>{{ candidature.offre.entreprise.nom }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="5">Aucune candidature</td>
            </tr>
          {% endfor %}
        </tbody>

      </table>
    </section>

  </div>
</main>

{% endblock %}
