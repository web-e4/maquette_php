<article class="card">
<div class="card-top">
    <div class="card-logo">
    <img src="/assets/icons/building-2.svg" alt="">
    </div>
    <h3 class="card-title">{{ offre.titre }}</h3>
</div>

<div class="card-meta">
    <span>
    <img src="/assets/icons/map-pin.svg" alt="">
    {{ offre.ville }}
    </span>
    <span>
    <img src="/assets/icons/clock.svg" alt="">
    {{ offre.duree }}
    </span>
</div>

<a class="card-cta" href="/offre?id={{ offre.id }}">
    Voir le détail
</a>
</article>