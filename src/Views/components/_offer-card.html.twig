{% set isInWishlist = (wishlistIds is defined and offer.idOffer in wishlistIds) %}

<article class="card">
  <div class="card-top">
    <div class="card-logo">
      <img src="{{ static_url }}/assets/icons/building-2.svg" alt="">
    </div>
    <h3 class="card-title">{{ offer.title }}</h3>

    {% if app_user is defined and app_user is not null and app_user.role == 'Etudiant' %}
      <form method="post"
            action="{{ isInWishlist ? '/wishlist/remove' : '/wishlist/add' }}?id={{ offer.idOffer }}"
            style="margin-left: auto; flex-shrink: 0">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <input type="hidden" name="redirect" value="{{ current_url }}">
        <button type="submit"
                class="btn-card-wishlist {{ isInWishlist ? 'btn-card-wishlist--active' : '' }}"
                title="{{ isInWishlist ? 'Retirer de la wish-list' : 'Ajouter à la wish-list' }}">
          <img src="{{ static_url }}/assets/icons/heart.svg" alt="">
        </button>
      </form>
    {% endif %}
  </div>

  <div class="card-meta">
    <span>
      <img src="{{ static_url }}/assets/icons/map-pin.svg" alt="">
      {{ offer.location }}
    </span>
    <span>
      <img src="{{ static_url }}/assets/icons/clock.svg" alt="">
      {{ offer.durationInWeeks }} semaines
    </span>
  </div>

  <a class="card-cta" href="/offer/{{ offer.idOffer }}">
    Voir le détail
  </a>
</article>
