{% extends "base.html.twig" %}

{% block title %}Administration{% endblock %}

{% block content %}

<main class="admin">
  <div class="container">

    <h1>Interface d'administration</h1>

    {% if success %}
      <div class="alert success">{{ success }}</div>
    {% endif %}

    {% if errors %}
      <div class="alert error">
        {% for error in errors %}
          <p>{{ error }}</p>
        {% endfor %}
      </div>
    {% endif %}

    <!-- ENTREPRISE -->
    <section>
      <h2>Entreprises</h2>

      {% include "admin/_company_create.html.twig" %}
      {% include "admin/_company_update.html.twig" %}
      {% include "admin/_company_delete.html.twig" %}
      {% include "admin/_company_evaluate.html.twig" %}
    </section>

    <!-- OFFRES -->
    <section>
      <h2>Offres</h2>

      {% include "admin/_offer_create.html.twig" %}
      {% include "admin/_offer_update.html.twig" %}
      {% include "admin/_offer_delete.html.twig" %}
    </section>

    <!-- PILOTES -->
    <section>
      <h2>Comptes pilotes</h2>

      {% include "admin/_pilot_create.html.twig" %}
      {% include "admin/_pilot_update.html.twig" %}
      {% include "admin/_pilot_delete.html.twig" %}
    </section>

    <!-- ETUDIANTS -->
    <section>
      <h2>Comptes étudiants</h2>

      {% include "admin/_student_create.html.twig" %}
      {% include "admin/_student_update.html.twig" %}
      {% include "admin/_student_delete.html.twig" %}
    </section>

  </div>
</main>

{% endblock %}
