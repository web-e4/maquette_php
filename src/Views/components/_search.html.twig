{#
  Variables optionnelles :
    searchAction      - action du formulaire       (défaut : /offers)
    searchPlaceholder - placeholder du champ texte (défaut : Trouver un stage...)
    searchShowCity    - afficher le champ ville     (défaut : true)
#}
{% set searchAction      = searchAction      ?? '/offers' %}
{% set searchPlaceholder = searchPlaceholder ?? 'Trouver un stage...' %}
{% set searchShowCity    = searchShowCity    is defined ? searchShowCity : true %}

<form class="search{% if not searchShowCity %} search--no-city{% endif %}" action="{{ searchAction }}" method="get">

    <div class="search-group">
        <input class="search-input" type="search" name="q" id="q-input" placeholder="{{ searchPlaceholder }}" value="{{ q ?? '' }}">
        <button class="search-clear-btn" type="button" id="q-clear-btn" aria-label="Vider la recherche" hidden>
            <img src="{{ static_url }}/assets/icons/x.svg" alt="">
        </button>
    </div>

    {% if searchShowCity %}
    <div class="search-group">
        <input class="search-input" type="text" name="city" id="city-input" placeholder="Taper une ville..." value="{{ city ?? '' }}">
        <button class="search-dropdown-btn" type="button" id="city-dropdown-btn" aria-label="Villes suggérées">
            <img src="{{ static_url }}/assets/icons/chevron-down.svg" alt="">
        </button>
        <ul class="search-dropdown" id="city-dropdown" hidden>
            {% set cities = ['Rouen', 'Lille', 'Marseille', 'Paris', 'Lyon'] %}
            {% for city in cities %}
                <li class="search-dropdown-item">{{ city }}</li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    <button class="search-btn" type="submit">Rechercher</button>

</form>

<script>
    // - Bouton effacer (champ "q") -
    const qInput    = document.getElementById('q-input');
    const qClearBtn = document.getElementById('q-clear-btn');

    function updateClear() {
        qClearBtn.hidden = qInput.value.trim() === '';
    }

    qInput.addEventListener('input', updateClear);
    qInput.addEventListener('focus', updateClear);
    qInput.addEventListener('blur', (e) => {
        if (e.relatedTarget !== qClearBtn) {
            qClearBtn.hidden = true;
        }
    });

    qClearBtn.addEventListener('click', () => {
        qInput.value = '';
        qClearBtn.hidden = true;
        qInput.focus();
    });

    const qGroup = qInput.closest('.search-group');

    qGroup.addEventListener('mouseenter', () => {
        if (qInput.value.trim() !== '') qClearBtn.hidden = false;
    });

    qGroup.addEventListener('mouseleave', () => {
        if (document.activeElement !== qInput) qClearBtn.hidden = true;
    });

    updateClear();

    {% if searchShowCity %}
    // - Dropdown villes -
    const cityBtn      = document.getElementById('city-dropdown-btn');
    const cityDropdown = document.getElementById('city-dropdown');
    const cityInput    = document.getElementById('city-input');

    cityBtn.addEventListener('click', () => {
        cityDropdown.hidden = !cityDropdown.hidden;
    });

    cityDropdown.addEventListener('click', (e) => {
        const item = e.target.closest('.search-dropdown-item');
        if (!item) return;
        cityInput.value = item.textContent;
        cityDropdown.hidden = true;
    });

    document.addEventListener('click', (e) => {
        if (!cityBtn.contains(e.target) && !cityDropdown.contains(e.target)) {
            cityDropdown.hidden = true;
        }
    });
    {% endif %}
</script>
