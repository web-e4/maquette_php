{% extends "base.html.twig" %}

{% block title %}Publier une offre{% endblock %}

{% block styles %}<link rel="stylesheet" href="{{ static_url }}/assets/css/publish.css">{% endblock %}

{% block content %}

<main class="publish-page">
  <div class="container">

    <!-- EN-TÊTE -->
    <div class="publish-header">
      <h1>Publier une offre de stage</h1>
      <p>Remplissez le formulaire ci-dessous pour mettre en ligne votre offre.</p>
    </div>

    <!-- ERREURS -->
    {% if errors is defined %}
      <div class="form-errors">
        <ul>
          {% for error in errors %}
            <li>{{ error }}</li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    <!-- FORMULAIRE -->
    <form class="publish-form" method="post" action="{{ editId is defined ? '/offer/edit?id=' ~ editId : '/offer/create/submit' }}">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

      <!-- Intitulé -->
      <div class="form-field">
        <label class="form-label" for="title">
          Intitulé de l'offre <span class="required">*</span>
        </label>
        <input class="form-input" type="text" id="title" name="title"
          value="{{ formData.title|default('') }}"
          placeholder="Ex : Stage Développeur Web" required>
      </div>

      <!-- Localisation -->
      <div class="form-field">
        <label class="form-label" for="location">
          Localisation <span class="required">*</span>
        </label>
        <input class="form-input" type="text" id="location" name="location"
          value="{{ formData.location|default('') }}"
          placeholder="Ex : Rouen (76)" required>
      </div>

      <!-- Durée -->
      <div class="form-field">
        <label class="form-label" for="duration">
          Durée (semaines) <span class="required">*</span>
        </label>
        <input class="form-input" type="number" id="duration" name="duration"
          value="{{ formData.duration|default('') }}"
          min="1" placeholder="Ex : 12" required>
      </div>

      <!-- Date de début -->
      <div class="form-field">
        <label class="form-label" for="startDate">
          Date de début <span class="required">*</span>
        </label>
        <input class="form-input" type="date" id="startDate" name="startDate"
          value="{{ formData.startDate|default('') }}" required>
      </div>

      <!-- Rémunération -->
      <div class="form-field">
        <label class="form-label" for="remuneration">
          Rémunération (€/mois)
        </label>
        <input class="form-input" type="number" id="remuneration" name="remuneration"
          value="{{ formData.remuneration|default('') }}"
          min="0" step="0.01" placeholder="Ex : 580">
      </div>

      <!-- Entreprise -->
      <div class="form-field">
        <label class="form-label" for="idCompany">
          Entreprise <span class="required">*</span>
        </label>
        <select class="form-input" id="idCompany" name="idCompany" required>
          <option value="">- Sélectionner une entreprise -</option>
          {% for company in companies %}
            <option value="{{ company.idCompany }}"
              {{ (formData.idCompany is defined and formData.idCompany == company.idCompany) ? 'selected' : '' }}>
              {{ company.name }}
            </option>
          {% endfor %}
        </select>
      </div>

      <!-- Compétences -->
      <div class="form-field field-full">
        <label class="form-label" for="skills">
          Compétences
        </label>
        <input class="form-input" type="text" id="skills" name="skills"
          value="{{ formData.skills|default('') }}"
          placeholder="Ex : PHP, JavaScript, MySQL">
        <span class="field-hint">Séparez chaque compétence par une virgule.</span>
      </div>

      <!-- Description -->
      <div class="form-field field-full">
        <label class="form-label" for="description">
          Description du poste <span class="required">*</span>
        </label>
        <textarea class="form-textarea" id="description" name="description"
          placeholder="Décrivez le contexte, l'équipe, les objectifs du stage..."
          required>{{ formData.description|default('') }}</textarea>
      </div>

      <!-- Missions -->
      <div class="form-field field-full">
        <label class="form-label" for="missions">
          Missions confiées <span class="required">*</span>
        </label>
        <textarea class="form-textarea" id="missions" name="missions"
          placeholder="Ex : Développer des fonctionnalités, Corriger les bugs, Rédiger la documentation"
          required>{{ formData.missions|default('') }}</textarea>
        <span class="field-hint">Séparez chaque mission par une virgule.</span>
      </div>

      <input type="hidden" name="redirectTo" value="{{ redirectTo|default('/offers') }}">

      <!-- Actions -->
      <div class="publish-actions">
        <button class="btn btn-solid" type="submit">
          <img src="{{ static_url }}/assets/icons/send.svg" alt="" class="icon-white">
          {{ editId is defined ? 'Enregistrer' : 'Publier l\'offre' }}
        </button>
        <a class="btn btn-ghost" href="{{ redirectTo|default('/offers') }}">Annuler</a>
      </div>

    </form>

  </div>
</main>

{% endblock %}
